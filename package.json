  "keywords": [
    "xdr",
    "adr",
    "decision-records",
    "ai-agents"
  ],
  "license": "MIT",
  "files": [
    ".xdrs/**",
    "package.json",
    "AGENTS.md",
    "bin/npmdata.js"
  ],
  "dependencies": {
    "npmdata": "^0.5.0"
  },
  "npmdata": [
    {
      "package": "xdrs",
      "outputDir": ".",
      "files": [
        ".github/**",
        ".xdrs/**"
      ]
    }
  ],
  "bin": "bin/npmdata.js"
}
